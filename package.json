{
  "name": "bees",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "preinstall": "node scripts/check-runtime.mjs",
    "postinstall": "node scripts/activity-daemon-setup.mjs",
    "setup:hermes": "node scripts/hermes-setup.mjs",
    "setup:asr": "node scripts/granite-asr-setup.mjs",
    "setup:activity": "node scripts/activity-daemon-setup.mjs",
    "dev": "node --import tsx scripts/dev.mjs",
    "dev:server": "node --import tsx scripts/dev.mjs",
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run build:server && npm run build:client && npm run build:assets",
    "build:client": "node scripts/build-client.mjs",
    "build:server": "tsc -p server/tsconfig.json",
    "build:assets": "node scripts/build-assets.mjs",
    "start": "node scripts/start.mjs",
    "prod": "npm run build && npm run start"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@streamdown/code": "^1.1.1",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.12.0",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.14.2",
    "react-router-dom": "^7.14.2",
    "streamdown": "^2.4.0",
    "uuid": "^11.0.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}

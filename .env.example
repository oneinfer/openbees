# All optional - defaults work for local development
PORT=6969
BEES_HOME=~/.bees
DB_PATH=~/.bees/data/bees.db

# Auth: Express issues JWTs for local sessions. Keep this aligned with
# OpenBees Enterprise when using the localhost SSO callback.
JWT_SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false

# Google OAuth (optional — enables Google Sign-In on the login page)
GOOGLE_CLIENT_ID=

# OpenBees Enterprise / OneInfer API connection.
# Set these when connecting to an OpenBees Enterprise instance for org/auth proxying.
ONEINFER_API_BASE_URL=http://localhost:8001/api/v1
VITE_ONEINFER_API_BASE_URL=http://localhost:8001/api/v1
VITE_OPENBEES_ENTERPRISE_APP_URL=https://openbees-enterprise.oneinfer.ai

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:6969
ENVIRONMENT=development

# Hermes worker discovery. Leave blank for auto-detection.
HERMES_AGENT_DIR=C:\Users\User\AppData\Local\hermes\hermes-agent
HERMES_PYTHON=C:\Users\User\AppData\Local\hermes\hermes-agent\venv\Scripts\python.exe
HERMES_HOME=C:\Users\User\AppData\Local\hermes\home
HERMES_AGENT_RUN_LIMIT=10              # Max concurrent agent runs in Python worker
HEARTBEAT_CONCURRENCY=2

# Default runtime for new tasks: hermes | codex | claude_code | opencode
BEES_DEFAULT_RUNTIME=hermes

# Optional command runtimes for repo-aware coding tasks.
BEES_CODEX_COMMAND=codex
BEES_CLAUDE_CODE_COMMAND=claude
BEES_OPENCODE_COMMAND=opencode

# Optional Granite ASR voice input.
GRANITE_ASR_ENABLED=true
GRANITE_ASR_PYTHON=C:\birdcode\.venv-granite-asr\Scripts\python.exe
GRANITE_ASR_MODEL=ibm-granite/granite-4.0-1b-speech
GRANITE_ASR_DEVICE=cpu
GRANITE_ASR_DTYPE=float32
GRANITE_ASR_MAX_AUDIO_MB=25
BEES_ASR_DEBUG_SAVE_AUDIO=false
# BEES_ASR_DEBUG_AUDIO_DIR=~/.bees/audio-debug/browser-asr

# Local desktop activity daemon.
BEES_ACTIVITY_ENABLED=true
BEES_ACTIVITY_HOST=127.0.0.1
BEES_ACTIVITY_PORT=4768
BEES_ACTIVITY_PYTHON=C:\birdcode\.venv-granite-asr\Scripts\python.exe
BEES_ACTIVITY_DATA_DIR=~/.bees/activity-daemon
BEES_ACTIVITY_REQUIRE_INPUT_DEVICE=true
WAKEWORD_ENGINE_ENABLED=true
WAKEWORD_THRESHOLD=0.2
WAKEWORD_POST_CAPTURE_SECONDS=2.0
WAKEWORD_ASR_FALLBACK_ENABLED=true
MIN_ENERGY_THRESHOLD=100
MIN_WAKE_AUDIO_RMS=80
SPEECH_DEBUG_SAVE_AUDIO=false
SPEECH_DEBUG_AUDIO_DIR=~/.bees/audio-debug
DEBUG_WAKE=0
DEBUG_WAKE_SCORES=0

LUX_TTS_ENABLED=false
LUX_TTS_PYTHON=
LUX_TTS_MODEL=YatharthS/LuxTTS
LUX_TTS_DEVICE=cpu
LUX_TTS_THREADS=2
LUX_TTS_REFERENCE_AUDIO_PATH=voice-reference.wav
LUX_TTS_NUM_STEPS=4
LUX_TTS_T_SHIFT=0.9
LUX_TTS_SPEED=1.0
LUX_TTS_RUN_LIMIT=1
LUX_TTS_SEGMENT_MAX_CHARS=420
LUX_TTS_SEGMENT_FLUSH_MS=900
LUX_TTS_QUEUE_MAX_SEGMENTS=12
LUX_TTS_SEGMENT_TIMEOUT_MS=30000
LUX_TTS_PRELOAD=true

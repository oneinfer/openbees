# All optional - defaults work for local development
PORT=6969
HERMES_AGENT_DIR=
HERMES_PYTHON=
HERMES_HOME=
HERMES_AGENT_RUN_LIMIT=10              # Max concurrent agent runs in Python worker
HEARTBEAT_CONCURRENCY=2
BEES_HOME=~/.bees
DB_PATH=~/.bees/data/bees.db

# Default runtime for new tasks: hermes | codex | claude_code | opencode
BEES_DEFAULT_RUNTIME=hermes

# Optional command runtimes for repo-aware coding tasks.
# Point each variable to a CLI command or wrapper script that can work in the repo.
# The app will pass task context through env vars such as:
# BEES_TASK_REPO, BEES_TASK_MESSAGE, BEES_TASK_PROMPT_FILE, BEES_TASK_CONTEXT_FILE

# You can also point these to wrapper scripts if you want a fixed model or extra flags.
BEES_CODEX_COMMAND=codex
BEES_CLAUDE_CODE_COMMAND=claude
BEES_OPENCODE_COMMAND=opencode

# Optional Qwen3-ASR voice input.
# npm run dev creates .venv-qwen-asr and installs qwen-asr if needed.
# Set BEES_SKIP_QWEN_ASR_INSTALL=1 before npm run dev to skip auto-install.
QWEN_ASR_ENABLED=true
QWEN_ASR_PYTHON=
QWEN_ASR_MODEL=Qwen/Qwen3-ASR-0.6B
QWEN_ASR_DEVICE=cpu
QWEN_ASR_DTYPE=float32
QWEN_ASR_MAX_AUDIO_MB=25

# Local desktop activity daemon.
# npm install prepares dependencies best-effort; npm run dev starts the daemon.
# Set BEES_SKIP_ACTIVITY_DAEMON_INSTALL=1 before npm install to skip dependency install.
BEES_ACTIVITY_ENABLED=true
BEES_ACTIVITY_HOST=127.0.0.1
BEES_ACTIVITY_PORT=4768
BEES_ACTIVITY_PYTHON=
BEES_ACTIVITY_DATA_DIR=~/.bees/activity-daemon
WAKEWORD_ENGINE_ENABLED=true
WAKEWORD_THRESHOLD=0.5
WAKEWORD_ASR_FALLBACK_ENABLED=true

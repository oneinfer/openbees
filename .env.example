# All optional — defaults work for local development
PORT=6969
HERMES_AGENT_DIR=C:\Users\Administrator\AppData\Local\hermes\hermes-agent
HERMES_PYTHON=C:\Users\Administrator\AppData\Local\hermes\hermes-agent\venv\Scripts\python.exe
HERMES_HOME=C:\Users\Administrator\AppData\Local\hermes\home
HERMES_AGENT_RUN_LIMIT=10              # Max concurrent agent runs in Python worker
HEARTBEAT_CONCURRENCY=2
MINIONS_HOME=~/.minions
DB_PATH=~/.minions/data/minions.db